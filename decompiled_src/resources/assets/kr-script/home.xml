<?xml version="1.0" encoding="UTF-8" ?>
<resource dir="file:///android_asset/samples" /> 
<group>
    <action auto-off="true">
          <title>Select Project</title>
          <set>echo $TSL > $TMPDIR/DNA.ini</set>
          <summary sh="echo 'Current Project: /sdcard/DNA' ;cat $TMPDIR/DNA.ini"/>          
          <param name="TSL" options-sh="samples/project.sh CK" required="true"/>
    </action>
   
    <action reload="true" auto-off="true">
           <title>Delete Project</title>
           <set>samples/project.sh SC</set>
           <param name="TSS"  multiple="true" options-sh="samples/project.sh CK" required="true"/>
    </action>
    
    <action reload="true" auto-off="true">
           <title>New Project</title>
           <set>samples/project.sh XJ</set>
           <param name="T" placeholder="Please enter the project name (non-Chinese):" required="true"/>
    </action>
    
    <action reload="true" interruptible="false">
           <title>Unzip ROM</title>
           <set>dna unzip --delete $silence $DNA_DIR/$ZIP $DNA_DIR</set>
           <param name="silence" label="Delete source files" type="checkbox" />
           <param name="ZIP" title="Please select the zip file:" options-sh="samples/findfile.sh zip1" desc="Put your files inside /sdcard/DNA project path" required="true"/>
    </action>

    <page title="Project Menu" config="file:///android_asset/kr-script/dna.xml">
            <lock>
                if [[ -f $TMPDIR/DNA.ini ]]; then
                    echo 'unlocked'
                else
                    echo 'Create a project first'
                fi
            </lock>
    </page>
</group>

