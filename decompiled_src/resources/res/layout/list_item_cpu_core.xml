<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="4dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginBottom="20dp">
    <LinearLayout
        android:layout_gravity="center_horizontal"
        android:orientation="vertical"
        android:background="@drawable/krscript_item_ripple"
        android:paddingBottom="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <FrameLayout
            android:layout_gravity="center"
            android:layout_width="49dp"
            android:layout_height="55dp"
            android:layout_marginTop="6dp">
            <com.dna.tools.ui.CpuChartBarView
                android:id="@+id/core_cpu_loading_chart"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.5"
                app:free="1"
                app:total="1"/>
            <TextView
                android:textSize="12dp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:id="@+id/cpu_core_load"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"/>
        </FrameLayout>
        <LinearLayout
            android:layout_gravity="center"
            android:orientation="vertical"
            android:id="@+id/center"
            android:paddingLeft="7dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_weight="1">
            <TextView
                android:textSize="12dp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"
                android:id="@+id/cpu_core_current_freq"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2048Mhz"
                android:lines="1"
                android:textAlignment="center"/>
            <TextView
                android:textSize="9dp"
                android:textColor="#88888888"
                android:id="@+id/cpu_core_freq_ranage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="300Mhz ~ 2048Mhz"
                android:textAlignment="center"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
