<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/title"
            style="@style/dialogTitle"/>
        <TextView
            android:id="@+id/desc"
            style="@style/dialogDesc"/>
        <TextView
            android:id="@+id/warn"
            android:text=""
            style="@style/dialogWarn"/>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/kr_params_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp"
        android:layout_below="@+id/top_bar">
        <com.omarea.common.ui.OverScrollView
            android:id="@+id/kr_params_center"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/bottom_actions"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/bottom_actions"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:layout_alignParentBottom="true"
            android:layout_marginVertical="16dp"
            android:paddingHorizontal="16dp">
            <Button
                android:id="@+id/btn_cancel"
                android:text="@string/btn_cancel"
                style="@style/dialogCancelBtn"/>
            <Button
                android:id="@+id/btn_confirm"
                android:text="@string/btn_confirm"
                style="@style/dialogConfirmBtn"/>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
